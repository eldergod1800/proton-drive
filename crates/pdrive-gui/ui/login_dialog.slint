import { VerticalBox, HorizontalBox } from "std-widgets.slint";

export component LoginDialog inherits Window {
    title: "Proton Drive";
    preferred-width: 400px;
    preferred-height: 580px;

    in-out property <bool>   dark-mode: false;
    in-out property <string> error-text: "";
    in-out property <bool>   busy: false;
    in-out property <bool>   show-verification: false;
    in-out property <string> verification-label: "Human verification required. Complete the captcha in the window that opened.";
    in-out property <string> captcha-url: "";
    in-out property <bool>   show-2fa: false;

    callback open-captcha-page-requested();
    callback login-requested(string /* username */, string /* password */);
    callback totp-requested(string /* totp code */);

    // ── Palette ───────────────────────────────────────────────────────────────
    property <color> c-bg:           dark-mode ? #1e1e2e : #f2f2f7;
    property <color> c-card:         dark-mode ? #24273a : #ffffff;
    property <color> c-text:         dark-mode ? #cdd6f4 : #1a1a2e;
    property <color> c-subtext:      dark-mode ? #a6adc8 : #666666;
    property <color> c-label:        dark-mode ? #a6adc8 : #444444;
    property <color> c-input-bg:     dark-mode ? #1e1e2e : #f8f8fc;
    property <color> c-input-border: dark-mode ? #45475a : #d0d0d8;
    property <color> c-input-focus:  dark-mode ? #cba6f7 : #6d4aff;
    property <color> c-placeholder:  dark-mode ? #585b70 : #bbbbbb;
    property <color> c-error-bg:     dark-mode ? #3d1f1f : #fff0f0;
    property <color> c-error-text:   dark-mode ? #f38ba8 : #d32f2f;
    property <color> c-info-bg:      dark-mode ? #1f2d3d : #eef3ff;
    property <color> c-info-text:    dark-mode ? #89b4fa : #444488;
    property <color> c-accent:       dark-mode ? #cba6f7 : #6d4aff;
    property <color> c-accent-h:     dark-mode ? #b08fe8 : #5a38e8;
    property <color> c-accent-dim:   dark-mode ? #7c6aad : #a08fff;

    background: c-bg;

    // ── Card ─────────────────────────────────────────────────────────────────
    Rectangle {
        background: root.c-card;
        border-radius: 16px;
        border-width: 1px;
        border-color: dark-mode ? #313244 : #e0e0e8;
        width: 340px;
        height: root.height - 40px;
        x: (root.width - self.width) / 2;
        y: 20px;

        VerticalBox {
            padding: 32px;
            padding-top: 20px;
            spacing: 0;

            // ── Header: dark mode toggle right, logo centered ─────────────────
            HorizontalBox {
                height: 30px;
                spacing: 0;
                padding: 0;
                alignment: stretch;
                // Spacer left (same width as toggle so logo centers)
                Rectangle { width: 30px; }
                // Logo hex — centered
                Text {
                    text: "⬡";
                    font-size: 26px;
                    color: root.c-accent;
                    horizontal-alignment: center;
                    horizontal-stretch: 1;
                    vertical-alignment: center;
                }
                // Dark mode toggle right
                Rectangle {
                    width: 30px;
                    height: 30px;
                    border-radius: 8px;
                    background: dm-touch.has-hover ? root.c-input-border : transparent;
                    dm-touch := TouchArea {
                        clicked => { root.dark-mode = !root.dark-mode; }
                    }
                    Text {
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        text: root.dark-mode ? "☀" : "☾";
                        font-size: 15px;
                        color: root.dark-mode ? #f9e2af : #888888;
                    }
                }
            }

            Rectangle { height: 6px; }

            Text {
                text: "Proton Drive";
                font-size: 20px;
                font-weight: 600;
                color: root.c-text;
                horizontal-alignment: center;
            }

            Rectangle { height: 4px; }

            Text {
                text: "Sign in to your account";
                font-size: 12px;
                color: root.c-subtext;
                horizontal-alignment: center;
            }

            Rectangle { height: 22px; }

            // ── Username ──────────────────────────────────────────────────────
            Text {
                text: "Email or username";
                font-size: 12px;
                font-weight: 600;
                color: root.c-label;
            }
            Rectangle { height: 6px; }
            Rectangle {
                height: 42px;
                border-radius: 8px;
                border-width: 1.5px;
                border-color: username-input.has-focus ? root.c-input-focus : root.c-input-border;
                background: root.c-input-bg;

                // Placeholder text (visible when empty)
                if username-input.text == "": Text {
                    x: 13px;
                    y: (parent.height - self.height) / 2;
                    text: "you@proton.me";
                    color: root.c-placeholder;
                    font-size: 13px;
                }

                username-input := TextInput {
                    x: 13px;
                    width: parent.width - 26px;
                    height: 20px;
                    y: (parent.height - self.height) / 2;
                    enabled: !root.busy;
                    color: root.c-text;
                    font-size: 13px;
                    accepted => { password-input.focus(); }
                }
            }

            Rectangle { height: 14px; }

            // ── Password ──────────────────────────────────────────────────────
            Text {
                text: "Password";
                font-size: 12px;
                font-weight: 600;
                color: root.c-label;
            }
            Rectangle { height: 6px; }
            Rectangle {
                height: 42px;
                border-radius: 8px;
                border-width: 1.5px;
                border-color: password-input.has-focus ? root.c-input-focus : root.c-input-border;
                background: root.c-input-bg;

                if password-input.text == "": Text {
                    x: 13px;
                    y: (parent.height - self.height) / 2;
                    text: "Password";
                    color: root.c-placeholder;
                    font-size: 13px;
                }

                password-input := TextInput {
                    x: 13px;
                    width: parent.width - 26px;
                    height: 20px;
                    y: (parent.height - self.height) / 2;
                    enabled: !root.busy;
                    input-type: InputType.password;
                    color: root.c-text;
                    font-size: 13px;
                    accepted => {
                        if !root.busy {
                            root.login-requested(username-input.text, password-input.text);
                        }
                    }
                }
            }

            Rectangle { height: 10px; }

            // ── Captcha section ────────────────────────────────────────────
            if root.show-verification: VerticalBox {
                spacing: 0;
                padding: 0;

                Rectangle {
                    height: 44px;
                    border-radius: 6px;
                    background: root.c-info-bg;
                    Text {
                        x: 10px;
                        width: parent.width - 20px;
                        y: (parent.height - self.height) / 2;
                        text: "Verification window opened — complete the captcha to continue.";
                        color: root.c-info-text;
                        font-size: 11px;
                        wrap: word-wrap;
                    }
                }

                Rectangle { height: 8px; }
            }

            // ── Error text ────────────────────────────────────────────────
            if root.error-text != "": Rectangle {
                height: 40px;
                border-radius: 6px;
                background: root.c-error-bg;
                Text {
                    x: 10px;
                    width: parent.width - 20px;
                    y: (parent.height - self.height) / 2;
                    text: root.error-text;
                    color: root.c-error-text;
                    font-size: 12px;
                    wrap: word-wrap;
                }
            }

            // ── 2FA section ────────────────────────────────────────────────
            if root.show-2fa: VerticalBox {
                spacing: 0;
                padding: 0;

                Text {
                    text: "Two-factor authentication";
                    font-size: 12px;
                    font-weight: 600;
                    color: root.c-label;
                }
                Rectangle { height: 6px; }
                Rectangle {
                    height: 42px;
                    border-radius: 8px;
                    border-width: 1.5px;
                    border-color: totp-input.has-focus ? root.c-input-focus : root.c-input-border;
                    background: root.c-input-bg;

                    if totp-input.text == "": Text {
                        x: 13px;
                        y: (parent.height - self.height) / 2;
                        text: "6-digit code";
                        color: root.c-placeholder;
                        font-size: 13px;
                    }

                    totp-input := TextInput {
                        x: 13px;
                        width: parent.width - 26px;
                        height: 20px;
                        y: (parent.height - self.height) / 2;
                        color: root.c-text;
                        font-size: 13px;
                    }
                }
                Rectangle { height: 10px; }
                if root.error-text == "": Rectangle { height: 36px; }
                Rectangle { height: 8px; }

                Rectangle {
                    height: 44px;
                    border-radius: 10px;
                    background: root.busy ? root.c-accent-dim : (totp-btn.has-hover ? root.c-accent-h : root.c-accent);
                    totp-btn := TouchArea {
                        enabled: !root.busy;
                        clicked => { root.totp-requested(totp-input.text); }
                    }
                    Text {
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        text: root.busy ? "Verifying..." : "Verify";
                        color: #ffffff;
                        font-size: 14px;
                        font-weight: 600;
                    }
                }
            }

            if root.error-text == "" && !root.show-2fa: Rectangle { height: 36px; }
            Rectangle { height: 8px; }

            // ── Sign in button ─────────────────────────────────────────────
            if !root.show-2fa: Rectangle {
                height: 44px;
                border-radius: 10px;
                background: root.busy ? root.c-accent-dim : (btn-touch.has-hover ? root.c-accent-h : root.c-accent);
                btn-touch := TouchArea {
                    enabled: !root.busy;
                    clicked => {
                        root.login-requested(username-input.text, password-input.text);
                    }
                }
                Text {
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    text: root.busy ? "Signing in..." : "Sign in";
                    color: #ffffff;
                    font-size: 14px;
                    font-weight: 600;
                }
            }
        }
    }
}
