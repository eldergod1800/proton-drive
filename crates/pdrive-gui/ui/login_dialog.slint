import { LineEdit, VerticalBox } from "std-widgets.slint";

export component LoginDialog inherits Window {
    title: "Proton Drive";
    preferred-width: 400px;
    preferred-height: 440px;
    background: #ffffff;

    in-out property <string> error-text: "";
    in-out property <bool>   busy: false;
    in-out property <bool>   show-verification: false;
    in-out property <string> verification-label: "Human verification required. Open the page in your browser, complete the captcha, then click Sign In.";
    in-out property <string> captcha-url: "";
    in-out property <bool>   show-2fa: false;

    callback open-captcha-page-requested();
    callback login-requested(string /* username */, string /* password */);
    callback totp-requested(string /* totp code */);

    Rectangle {
        background: #ffffff;

        VerticalBox {
            padding: 40px;
            spacing: 0;

            // Logo area
            Rectangle {
                height: 80px;
                VerticalBox {
                    spacing: 4px;
                    alignment: center;
                    Text {
                        text: "⬡";
                        font-size: 36px;
                        color: #6d4aff;
                        horizontal-alignment: center;
                    }
                    Text {
                        text: "Proton Drive";
                        font-size: 22px;
                        font-weight: 700;
                        color: #1a1a2e;
                        horizontal-alignment: center;
                    }
                }
            }

            Rectangle { height: 8px; }

            Text {
                text: "Sign in to your account";
                font-size: 13px;
                color: #888888;
                horizontal-alignment: center;
            }

            Rectangle { height: 28px; }

            // Username
            Text {
                text: "Email or username";
                font-size: 12px;
                font-weight: 600;
                color: #444444;
            }
            Rectangle { height: 6px; }
            username-field := LineEdit {
                placeholder-text: "you@proton.me";
                enabled: !root.busy;
                height: 40px;
            }

            Rectangle { height: 16px; }

            // Password
            Text {
                text: "Password";
                font-size: 12px;
                font-weight: 600;
                color: #444444;
            }
            Rectangle { height: 6px; }
            password-field := LineEdit {
                placeholder-text: "Password";
                input-type: password;
                enabled: !root.busy;
                height: 40px;
            }

            Rectangle { height: 8px; }

            // Captcha verification section (shown only when show-verification is true)
            if root.show-verification: VerticalBox {
                spacing: 0;
                padding: 0;

                Rectangle {
                    height: 52px;
                    border-radius: 6px;
                    background: #f0f4ff;

                    Text {
                        x: 10px;
                        width: parent.width - 20px;
                        y: (parent.height - self.height) / 2;
                        text: root.verification-label;
                        color: #444488;
                        font-size: 12px;
                        wrap: word-wrap;
                    }
                }

                Rectangle { height: 8px; }

                Rectangle {
                    height: 36px;
                    border-radius: 8px;
                    background: root.busy ? #d0d0d0 : (captcha-touch.has-hover ? #5a38e8 : #6d4aff);

                    captcha-touch := TouchArea {
                        enabled: !root.busy;
                        clicked => {
                            root.open-captcha-page-requested();
                        }
                    }

                    Text {
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        text: "Open Verification Page";
                        color: #ffffff;
                        font-size: 12px;
                        font-weight: 600;
                    }
                }

                Rectangle { height: 6px; }

                // Copyable URL so user can paste into private/incognito window
                Text {
                    text: "Or copy URL to paste in a private browser window:";
                    font-size: 11px;
                    color: #888888;
                    wrap: word-wrap;
                }
                Rectangle { height: 4px; }
                url-field := LineEdit {
                    text: root.captcha-url;
                    enabled: true;
                    height: 32px;
                    font-size: 10px;
                }

                Rectangle { height: 8px; }
            }

            // Error text
            if root.error-text != "": Rectangle {
                height: 36px;
                border-radius: 6px;
                background: #fff0f0;

                Text {
                    x: 10px;
                    y: (parent.height - self.height) / 2;
                    text: root.error-text;
                    color: #d32f2f;
                    font-size: 12px;
                    wrap: word-wrap;
                }
            }

            // 2FA section (shown only when show-2fa is true) — input + Verify button in one block
            if root.show-2fa: VerticalBox {
                spacing: 0;
                padding: 0;

                Text {
                    text: "Two-factor authentication";
                    font-size: 12px;
                    font-weight: 600;
                    color: #444444;
                }
                Rectangle { height: 6px; }
                totp-field := LineEdit {
                    placeholder-text: "6-digit code";
                    height: 40px;
                }
                Rectangle { height: 8px; }

                if root.error-text == "": Rectangle { height: 36px; }

                Rectangle { height: 8px; }

                Rectangle {
                    height: 44px;
                    border-radius: 10px;
                    background: root.busy
                        ? #a08fff
                        : (totp-btn-touch.has-hover ? #5a38e8 : #6d4aff);

                    totp-btn-touch := TouchArea {
                        enabled: !root.busy;
                        clicked => {
                            root.totp-requested(totp-field.text);
                        }
                    }

                    Text {
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        text: root.busy ? "Verifying..." : "Verify";
                        color: #ffffff;
                        font-size: 14px;
                        font-weight: 600;
                    }
                }
            }

            if root.error-text == "" && !root.show-2fa: Rectangle { height: 36px; }

            Rectangle { height: 8px; }

            // Sign in button (hidden when 2FA is active)
            if !root.show-2fa: Rectangle {
                height: 44px;
                border-radius: 10px;
                background: root.busy
                    ? #a08fff
                    : (btn-touch.has-hover ? #5a38e8 : #6d4aff);

                btn-touch := TouchArea {
                    enabled: !root.busy;
                    clicked => {
                        root.login-requested(
                            username-field.text,
                            password-field.text,
                        );
                    }
                }

                Text {
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    text: root.busy ? "Signing in..." : "Sign in";
                    color: #ffffff;
                    font-size: 14px;
                    font-weight: 600;
                }
            }
        }
    }
}
